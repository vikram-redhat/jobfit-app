# Supabase - get these from your Supabase project Settings > API
# "Project URL" and "Project API keys > publishable" (also labelled anon/public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here

# Anthropic - get from platform.claude.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App URL - update for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
